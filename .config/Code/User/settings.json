{
  "ltex.language": "auto",
  "python.defaultInterpreterPath": "/usr/sbin/python3.14",
  "workbench.colorCustomizations": {},
  "GitLive.Special branches": "main|master|trunk|dev|develop|qa|test|release[-/].*",
  "GitLive.Issue tracker integration": "Disabled",
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "githubPullRequests.pullBranch": "never",
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
  },
  "python.formatting.provider": "none",
  "diffEditor.ignoreTrimWhitespace": false,
  "gitlens.views.commits.files.layout": "list",
  "files.watcherExclude": {
    "**/.bloop": true,
    "**/.metals": true,
    "**/.ammonite": true,
  },
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": false,
    "quarto": false,
    "scala": false,
    "python": true,
    "yaml": true,
    "sql": false,
    "cuda-cpp": true,
    "c": true,
    "shellscript": true,
    "jsonc": true,
    "dockerfile": true,
    "dockercompose": true,
    "rust": true,
    "asm-intel-x86-generic": false,
    "latex": true,
    "haskell": false,
    "cpp": true,
  },
  "editor.fontVariations": true,
  "editor.fontLigatures": true,
  "editor.fontFamily": "JetBrains Mono, Fira Code, Menlo, Monaco, 'Courier New', monospace",
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[java]": {
    "editor.defaultFormatter": "redhat.java",
  },
  "emeraldwalk.runonsave": {
    "commands": [
      {
        "match": "\\.p\\.md$",
        "cmd": "myfile=${fileBasename} && pandoc ${file} -o ${fileDirname}/${myfile%%.*}.pdf",
      },
    ],
  },
  "githubPullRequests.createOnPublishBranch": "never",
  "editor.defaultFoldingRangeProvider": "charliermarsh.ruff",
  "black-formatter.args": [
    "--safe"
  ],
  "terminal.integrated.scrollback": 1000000,
  "terminal.integrated.persistentSessionScrollback": 1000000,
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "glassit.alpha": 215,
  "[php]": {
    "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
  },
  "dart.flutterSdkPath": "/home/silas/.local/share/flutter",
  "omnisharp.useModernNet": false,
  "github.copilot.editor.enableAutoCompletions": true,
  "java.imports.gradle.wrapper.checksums": [
    {
      "sha256": "2a2ac325379e29446c08f714a7cc498cdde42c25508f629fecaca95fe81aee20",
      "allowed": true,
    },
  ],
  "githubPullRequests.pushBranch": "always",
  "cmake.showOptionsMovedNotification": false,
  "C_Cpp.default.cppStandard": "c++23",
  "C_Cpp.default.intelliSenseMode": "linux-clang-x64",
  "makefile.configureOnOpen": true,
  "cmake.pinnedCommands": [
    "workbench.action.tasks.configureTaskRunner",
    "workbench.action.tasks.runTask",
  ],
  "C_Cpp.inlayHints.autoDeclarationTypes.enabled": true,
  "C_Cpp.inlayHints.autoDeclarationTypes.showOnLeft": true,
  "C_Cpp.inlayHints.parameterNames.enabled": true,
  "C_Cpp.inlayHints.referenceOperator.enabled": true,
  "editor.formatOnSave": true,
  "latex-workshop.latex.outDir": "build",
  "latex-workshop.latex.build.enableMagicComments": false,
  "languageToolLinter.languageTool.level": "picky",
  "languageToolLinter.languageTool.motherTongue": "de",
  "languageToolLinter.lintOnChange": true,
  "languageToolLinter.lintOnOpen": true,
  "languageToolLinter.plainText.languageIds": [
    "plaintext",
    "tex",
    "latex"
  ],
  "languageToolLinter.languageTool.preferredVariants": "en-US, de-DE",
  "ltex.completionEnabled": true,
  "ltex.additionalRules.enablePickyRules": true,
  "[latex]": {
    "editor.defaultFormatter": "James-Yu.latex-workshop",
  },
  "flake8.severity": {
    "E501": "Hint",
  },
  "C_Cpp.clang_format_style": "file",
  "C_Cpp.clang_format_fallbackStyle": "Microsoft",
  "python.analysis.autoImportCompletions": true,
  "editor.wordWrap": "on",
  "C_Cpp.formatting": "clangFormat",
  "C_Cpp.default.compileCommands": [
    "build"
  ],
  "C_Cpp.default.compilerPath": "/usr/bin/clang++",
  "[shellscript]": {
    "editor.defaultFormatter": "mkhl.shfmt",
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
  },
  "C_Cpp.default.browse.limitSymbolsToIncludedHeaders": false,
  "[dart]": {
    "editor.inlayHints.enabled": "on",
  },
  "clangd.arguments": [
    "--function-arg-placeholders=0"
  ],
  "python.analysis.typeCheckingMode": "standard",
  "[cpp]": {},
  "github.copilot.nextEditSuggestions.enabled": false,
  "docker.extension.enableComposeLanguageServer": false,
  "java.jdt.ls.androidSupport.enabled": "on",
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.referencesCodeLens.enabled": true,
  "java.compile.nullAnalysis.mode": "automatic",
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
    "files.trimTrailingWhitespace": false,
  },
  "kotlin.languageServer.enabled": false,
  "kotlin.debugAdapter.enabled": false,
  "[cmake]": {
    "editor.defaultFormatter": "KylinIdeTeam.cmake-intellisence",
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true,
    },
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "gitlens.remotes": [
    {
      "domain": "git.rwth-aachen.de",
      "type": "GitLab"
    },
    {
      "domain": "gitlab.com",
      "type": "GitLab"
    },
    {
      "domain": "github.com",
      "type": "GitHub"
    },
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk (lualatex)",
      "tools": [
        "lualatexmk"
      ],
    },
    {
      "name": "latexmk",
      "tools": [
        "latexmk"
      ],
    },
    {
      "name": "latexmk (latexmkrc)",
      "tools": [
        "latexmk_rconly"
      ],
    },
    {
      "name": "latexmk (xelatex)",
      "tools": [
        "xelatexmk"
      ],
    },
    {
      "name": "pdflatex -> bibtex -> pdflatex * 2",
      "tools": [
        "pdflatex",
        "bibtex",
        "pdflatex",
        "pdflatex"
      ],
    },
    {
      "name": "Compile Rnw files",
      "tools": [
        "rnw2tex",
        "latexmk"
      ],
    },
    {
      "name": "Compile Jnw files",
      "tools": [
        "jnw2tex",
        "latexmk"
      ],
    },
    {
      "name": "Compile Pnw files",
      "tools": [
        "pnw2tex",
        "latexmk"
      ],
    },
    {
      "name": "tectonic",
      "tools": [
        "tectonic"
      ],
    },
  ],
  "zig.zls.enabled": "on",
  "terminal.integrated.suggest.enabled": false,
  "terminal.integrated.sendKeybindingsToShell": true,
  "terminal.integrated.allowMnemonics": false,
  "terminal.integrated.gpuAcceleration": "off",
  "terminal.integrated.macOptionIsMeta": false,
  "terminal.integrated.altClickMovesCursor": false,
  "terminal.integrated.commandsToSkipShell": [],
  "terminal.integrated.env.linux": {
    "TERM": "xterm",
  },
  "terminal.external.linuxExec": "alacritty",
  "keyboard.dispatch": "code",
  "dafny.cliPath": "/usr/bin/dafny",
  "black-formatter.importStrategy": "fromEnvironment",
  "latex-workshop.formatting.latex": "tex-fmt",
  "latex-workshop.formatting.tex-fmt.args": [],
  "chat.viewSessions.orientation": "stacked",
  "diffEditor.maxComputationTime": 0,
  "git.blame.editorDecoration.enabled": true,
  "git.blame.statusBarItem.enabled": false,
  "workbench.colorTheme": "Dark Modern",
  "C_Cpp.intelliSenseEngine": "disabled",
  "[toml]": {
    "editor.defaultFormatter": "tombi-toml.tombi",
  },
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
}
